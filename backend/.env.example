# ==============================================
# 淬 · Anneal — 环境配置
# ==============================================
# cp .env.example .env && 填入真实值

# ----------------------------------------------
# LLM 配置 (必填)
# ----------------------------------------------
# Provider: anthropic | openai
# "openai" 兼容 DeepSeek / 百炼 / Together / Groq / OpenRouter
ANNEAL_LLM_PROVIDER=anthropic
ANNEAL_LLM_KEY=sk-ant-your-key
ANNEAL_LLM_MODEL=claude-sonnet-4-20250514
ANNEAL_LLM_BASE_URL=https://api.anthropic.com

# --- DeepSeek 示例 ---
# ANNEAL_LLM_PROVIDER=openai
# ANNEAL_LLM_KEY=sk-your-key
# ANNEAL_LLM_MODEL=deepseek-chat
# ANNEAL_LLM_BASE_URL=https://api.deepseek.com/v1

# ----------------------------------------------
# 学术搜索 API (推荐, 不填也能用)
# ----------------------------------------------
# NCBI / PubMed (有 key: 10 req/s, 无: 3 req/s)
NCBI_EMAIL=your.email@example.com
NCBI_API_KEY=your-ncbi-api-key

# OpenAlex (无需 key; 填邮箱进入 polite pool, 更稳的限流)
# OPENALEX_CONTACT=your.email@example.com

# Semantic Scholar
# SEMANTIC_SCHOLAR_API_KEY=your-s2-key

# Google Scholar (via SerpApi, 免费 100 次/月)
# SERPAPI_KEY=your-serpapi-key

# ----------------------------------------------
# 数据目录 (可选)
# ----------------------------------------------
# ANNEAL_DATA_DIR=~/.anneal/data

# ----------------------------------------------
# 数据库 (PostgreSQL)
# ----------------------------------------------
ANNEAL_DATABASE_URL=postgresql://localhost:5432/anneal
